rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isResourceOwner() { return isSignedIn() && resource.data.userId == request.auth.uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['userId', 'googleDocId', 'status', 'createdAt'])
        && data.userId == request.auth.uid
        && data.googleDocId is string && data.googleDocId.size() <= 256
        && data.status in ['pending', 'processing', 'completed', 'failed']
        && (data.get('googleDocTitle', null) == null || (data.googleDocTitle is string && data.googleDocTitle.size() <= 512))
        && (data.get('manualContent', null) == null || (data.manualContent is string && data.manualContent.size() <= 1048576))
        && (data.get('asciiDocContent', '') == '' || (data.asciiDocContent is string && data.asciiDocContent.size() <= 1048576))
        && data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'googleToken', 'githubToken']);
    }

    match /jobs/{jobId} {
      allow get: if isResourceOwner();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidJob(incoming());
        
      allow update: if isResourceOwner()
        && (
          // Action: Pipeline Status Shift
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'asciiDocContent', 'githubPrUrl', 'error', 'googleDocTitle']))
          && incoming().userId == existing().userId
          && incoming().googleDocId == existing().googleDocId
          && incoming().createdAt == existing().createdAt
        );

      allow delete: if isResourceOwner();
    }
  }
}
